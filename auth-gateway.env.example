# Copy to /usr/local/bin/auth-gateway.env on Pi5 and fill in real values
# chmod 600 /usr/local/bin/auth-gateway.env

# Telegram bot token (same as noc_bot)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram chat ID to receive OTP codes
TELEGRAM_CHAT_ID=502550514

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_secret_here

# OTP expiry in seconds (default: 300 = 5 minutes)
OTP_TTL=300

# Session TTL in seconds (default: 14400 = 4 hours)
SESSION_TTL=14400

# SQLite database path
DB_FILE=/home/uri/auth_gateway.db

# Admin username (only this user can access /auth/admin)
ADMIN_USER=uri
